" https://www.shortcutfoo.com/blog/top-50-vim-configuration-options/

" Indentation
set autoindent
set expandtab
set tabstop=4

" Search
set hlsearch
set ignorecase
set incsearch

" Text
set incsearch
set linebreak
set scrolloff=1
set sidescrolloff=5
syntax enable
set wrap

" UI
set laststatus=2
set ruler
set cursorline
set relativenumber
set mouse=a
set title
set background=dark

colorscheme wombat256mod

" Misc
set autoread
set confirm
set history=1000
"set spell
